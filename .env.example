# Copy to .env and fill in real values.

# SQLite database file. Production: file:/config/db.sqlite
DATABASE_URL="file:./dev.db"

# Auth.js (NextAuth v5) JWT signing secret. REQUIRED.
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Encryption key for sensitive Settings columns (e.g. Lidarr API key). REQUIRED.
# Generate with: openssl rand -base64 32
AUDIOSEERR_SECRET=""

# YouTube Data API v3 key. Optional — enables the in-app YouTube player on
# track rows. Without it, the YouTube button opens a search in a new tab.
# Get one at https://console.cloud.google.com/apis/credentials (enable
# "YouTube Data API v3"). 10,000 units/day free → ~100 searches/day, plenty
# given results are cached for 30 days per artist+title.
YOUTUBE_API_KEY=""

# Optional: repository used by the in-app update banner. Defaults to this
# project repo; override it for forks that publish their own releases/tags.
AUDIOSEERR_UPDATE_REPO="Gizmotec/audioseerr"

# Path mappings for in-app playback are configured via the admin settings
# page (Library section), not env vars — they're stored in the DB so they
# can be edited without a container restart.
