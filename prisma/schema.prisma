// Audioseerr v1 schema
// Source of truth: docs/plans/2026-05-03-audioseerr-design.md §6

// Using the legacy prisma-client-js generator so `@prisma/client` re-exports
// the runtime correctly. Prisma 7's new prisma-client generator emits .ts only
// and requires direct imports from the output path, which trips Turbopack.
generator client {
  provider = "prisma-client-js"
}

// Connection URL is configured in prisma.config.ts (Prisma 7 convention).
// Runtime PrismaClient is constructed with @prisma/adapter-better-sqlite3 in src/lib/db.ts.
datasource db {
  provider = "sqlite"
}

enum Role {
  USER
  ADMIN
}

enum RequestType {
  ALBUM
  ARTIST
  TRACK
}

enum RequestStatus {
  PENDING
  APPROVED
  DECLINED
  DOWNLOADING
  AVAILABLE
  FAILED
}

enum LikeTargetType {
  TRACK
  ALBUM
  ARTIST
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  username     String    @unique
  passwordHash String
  role         Role      @default(USER)
  requestQuota Int       @default(20)
  createdAt    DateTime  @default(now())
  requests     Request[]
  likes        Like[]
  recentSearches RecentSearch[]
  playlists      Playlist[]
  plays          PlayHistory[]
  invitesCreated Invite[] @relation("InvitesCreated")
  invitesUsed    Invite[] @relation("InvitesUsed")
}

model Request {
  id               String        @id @default(cuid())
  type             RequestType
  mbid             String
  title            String
  artistName       String
  coverUrl         String?
  albumMbid        String?
  albumTitle       String?
  recordingMbid    String?
  albumPosition    Int?
  status           RequestStatus @default(PENDING)
  requestedById    String
  requestedBy      User          @relation(fields: [requestedById], references: [id])
  requestedAt      DateTime      @default(now())
  approvedAt       DateTime?
  declineReason    String?
  lidarrId         Int?
  qualityProfileId Int?
  torrentHash      String?
  downloadTitle    String?

  @@index([status])
  @@index([requestedById])
  @@index([type, mbid])
}

model LibraryItem {
  mbid             String   @id
  lidarrId         Int      @unique
  status           String
  artistName       String
  title            String
  trackFileCount   Int      @default(0)
  totalTrackCount  Int      @default(0)
  lastSyncedAt     DateTime
}

model Settings {
  id                     Int     @id @default(1)
  lidarrUrl              String?
  lidarrApiKey           String?
  lidarrDefaultProfileId Int?
  lidarrRootFolderPath   String?
  prowlarrUrl            String?
  prowlarrApiKey         String?
  qbittorrentUrl         String?
  qbittorrentUsername    String?
  qbittorrentPassword    String?
  trackTorrentCategory   String?
  trackTorrentSavePath   String?
  trackTorrentMaxSizeMb  Int     @default(200)
  lastFmApiKey           String?
  // Comma-separated `lidarrPath:localPath` pairs for bridging filesystem
  // differences between the Lidarr container and Audioseerr (e.g. when
  // Lidarr writes to /music but Audioseerr mounts the library at /data).
  // Empty/null means no remapping.
  mediaPathMap           String?
  requireApproval        Boolean @default(true)
  registrationMode       String  @default("CLOSED")
  setupComplete          Boolean @default(false)
}

model ApiCache {
  key       String   @id
  value     String
  expiresAt DateTime

  @@index([expiresAt])
}

// Polymorphic per-user likes for tracks, albums, and artists. Cached metadata
// (title/artistName/coverUrl/albumMbid) lets us render a "Liked items" view
// later without re-fetching MusicBrainz for every row.
//
// targetId conventions:
//   - ALBUM  → release-group MBID
//   - ARTIST → artist MBID
//   - TRACK  → recording MBID (stable across reissues; album context is
//              captured separately in albumMbid for navigation)
model Like {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType   LikeTargetType
  targetId     String
  title        String
  artistName   String?
  albumMbid    String?
  albumTitle   String?
  coverUrl     String?
  createdAt    DateTime       @default(now())

  @@unique([userId, targetType, targetId])
  @@index([userId, targetType])
}

// Per-user album-search history. Upserted on every search submission so a
// repeated query bumps `lastSearchedAt` rather than creating a duplicate row.
model RecentSearch {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query          String
  lastSearchedAt DateTime @default(now())

  @@unique([userId, query])
  @@index([userId, lastSearchedAt])
}

model Invite {
  token       String    @id
  createdById String
  createdBy   User      @relation("InvitesCreated", fields: [createdById], references: [id])
  expiresAt   DateTime
  usedAt      DateTime?
  usedById    String?
  usedBy      User?     @relation("InvitesUsed", fields: [usedById], references: [id])
}

// User-curated ordered list of tracks the user has in their Lidarr library.
// Tracks live in PlaylistTrack with dense 1-indexed positions; reorders
// renumber the affected rows in a single transaction.
model Playlist {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  coverUrl    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  tracks      PlaylistTrack[]

  @@index([userId])
}

// One play counted per track per "playthrough." A play is recorded once
// playback crosses the Last.fm-style threshold (50% of the track or 4 minutes,
// whichever is sooner; tracks shorter than 30s never count). The threshold
// match means we can later compare against Last.fm scrobbles apples-to-apples.
//
// recordingMbid follows the same convention as PlaylistTrack — a real
// MusicBrainz recording MBID where we have one, otherwise a `lidarr:<id>`
// pseudo-id (Lidarr doesn't expose recording MBIDs). albumMbid + artistName
// are denormalized so we can render "most-played albums/artists" without
// joining against external metadata.
model PlayHistory {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recordingMbid String
  albumMbid     String?
  artistName    String
  title         String
  durationMs    Int?
  playedMs      Int
  playedAt      DateTime @default(now())

  @@index([userId, playedAt])
  @@index([userId, recordingMbid])
  @@index([userId, albumMbid])
}

// One row per track in a playlist. Duplicates of the same recordingMbid are
// allowed (sometimes you want the same track twice in a row).
//
// trackFileId is the last-known Lidarr id and may go stale across re-imports.
// Lidarr's track API doesn't expose recording MBIDs, so the heal path keys on
// `albumPosition` (1-indexed track number on the album) — the same key the
// album page uses via buildTrackFileLookup. recordingMbid is kept for future
// MB-side lookups and as a stable display identity.
model PlaylistTrack {
  id            String   @id @default(cuid())
  playlistId    String
  playlist      Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  position      Int
  recordingMbid String
  trackFileId   Int
  albumMbid     String
  albumPosition Int
  title         String
  artistName    String
  albumTitle    String?
  coverUrl      String?
  durationMs    Int?
  addedAt       DateTime @default(now())

  @@index([playlistId, position])
}
