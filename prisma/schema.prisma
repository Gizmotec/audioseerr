// Audioseerr v1 schema
// Source of truth: docs/plans/2026-05-03-audioseerr-design.md §6

// Using the legacy prisma-client-js generator so `@prisma/client` re-exports
// the runtime correctly. Prisma 7's new prisma-client generator emits .ts only
// and requires direct imports from the output path, which trips Turbopack.
generator client {
  provider = "prisma-client-js"
}

// Connection URL is configured in prisma.config.ts (Prisma 7 convention).
// Runtime PrismaClient is constructed with @prisma/adapter-better-sqlite3 in src/lib/db.ts.
datasource db {
  provider = "sqlite"
}

enum Role {
  USER
  ADMIN
}

enum RequestType {
  ALBUM
  ARTIST
  TRACK
}

enum RequestStatus {
  PENDING
  APPROVED
  DECLINED
  DOWNLOADING
  AVAILABLE
  FAILED
}

enum LikeTargetType {
  TRACK
  ALBUM
  ARTIST
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  username     String    @unique
  passwordHash String
  role         Role      @default(USER)
  // When true for a given request type, requests of that type from this user
  // skip the admin approval queue and go straight to APPROVED/DOWNLOADING.
  // Admin toggles per-user-per-type from /admin/users.
  autoApproveArtist Boolean @default(false)
  autoApproveAlbum  Boolean @default(false)
  autoApproveTrack  Boolean @default(false)
  requestQuota Int       @default(20)
  // Per-user Spotify OAuth credentials. Each user registers their own Spotify
  // app (sidesteps the 25-user dev-mode cap that a single shared app would
  // hit) and pastes its Client ID here, then completes the OAuth dance.
  // PKCE flow — no client secret needed. Tokens are AES-256-GCM encrypted
  // via src/lib/encryption.ts.
  spotifyClientId       String?
  spotifyAccessToken    String?
  spotifyRefreshToken   String?
  spotifyTokenExpiresAt DateTime?
  createdAt    DateTime  @default(now())
  requests     Request[]
  likes        Like[]
  recentSearches RecentSearch[]
  playlists      Playlist[]
  plays          PlayHistory[]
  invitesCreated Invite[] @relation("InvitesCreated")
  invitesUsed    Invite[] @relation("InvitesUsed")
  libraryItems   UserLibraryItem[]
  downloadedTracks UserDownloadedTrack[]
  spotifyImports SpotifyPlaylistImport[]
  playlistSubscriptions PlaylistSubscription[]
}

model Request {
  id               String        @id @default(cuid())
  type             RequestType
  mbid             String
  title            String
  artistName       String
  coverUrl         String?
  albumMbid        String?
  albumTitle       String?
  recordingMbid    String?
  albumPosition    Int?
  status           RequestStatus @default(PENDING)
  requestedById    String
  requestedBy      User          @relation(fields: [requestedById], references: [id], onDelete: Cascade)
  requestedAt      DateTime      @default(now())
  approvedAt       DateTime?
  declineReason    String?
  lidarrId         Int?
  qualityProfileId Int?
  torrentHash      String?
  downloadTitle    String?
  // In-flight Soulseek transfer handle for TRACK requests (slskd path). The
  // sync job polls slskd for (username, file) to detect completion, then
  // registers a DownloadedTrack. torrentHash above is the legacy qBittorrent
  // handle, retained only for rows created before the slskd switchover.
  slskdUsername    String?
  slskdFile        String?
  // For ALBUM requests fetched via slskd: JSON array mapping each downloaded
  // file to its album position, computed at approval (with candidate durations)
  // so the sync job can register each finished track without re-matching.
  slskdFilesJson   String?
  // For TRACK requests: the ranked shortlist of {username,filename,size}
  // candidates from the Soulseek search. slskdUsername/slskdFile point at the
  // one currently downloading; on a transfer error the sync job fails over to
  // the next entry instead of giving up.
  slskdCandidatesJson String?
  // Set when this TRACK request is a discovery-mix pre-download: the resulting
  // DownloadedTrack is created ephemeral with this expiry. A non-ephemeral
  // request landing on the same track graduates it to permanent.
  ephemeral        Boolean       @default(false)
  expiresAt        DateTime?

  @@index([status])
  @@index([requestedById])
  @@index([type, mbid])
}

model LibraryItem {
  mbid             String   @id
  // Derived album-library index (rebuilt from DownloadedTrack by
  // syncDownloadedLibrary). lidarrId is vestigial — null for slskd-sourced
  // albums, retained only for rows migrated from the old Lidarr sync.
  lidarrId         Int?
  status           String
  artistName       String
  title            String
  trackFileCount   Int      @default(0)
  totalTrackCount  Int      @default(0)
  lastSyncedAt     DateTime
  users            UserLibraryItem[]
}

// Per-user view onto LibraryItem. The Lidarr-synced LibraryItem table is the
// global source of truth for what's on disk; UserLibraryItem partitions
// visibility so each invited user sees their own collection. Admin's row set
// is backfilled from the existing library on migration.
model UserLibraryItem {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  mbid        String
  libraryItem LibraryItem @relation(fields: [mbid], references: [mbid], onDelete: Cascade)
  addedAt     DateTime    @default(now())

  @@unique([userId, mbid])
  @@index([userId])
}

model Settings {
  id                     Int     @id @default(1)
  lidarrUrl              String?
  lidarrApiKey           String?
  lidarrDefaultProfileId Int?
  lidarrRootFolderPath   String?
  prowlarrUrl            String?
  prowlarrApiKey         String?
  qbittorrentUrl         String?
  qbittorrentUsername    String?
  qbittorrentPassword    String?
  trackTorrentCategory   String?
  trackTorrentSavePath   String?
  trackTorrentMaxSizeMb  Int     @default(200)
  // Soulseek (slskd) — the single-song download source. apiKey is AES-256-GCM
  // encrypted at rest (see src/lib/encryption.ts). downloadPath is slskd's
  // completed-downloads directory as slskd reports it; it's translated to a
  // path Audioseerr can read via mediaPathMap, the same bridge used for Lidarr.
  slskdUrl               String?
  slskdApiKey            String?
  slskdDownloadPath      String?
  lastFmApiKey           String?
  // Comma-separated `lidarrPath:localPath` pairs for bridging filesystem
  // differences between the Lidarr container and Audioseerr (e.g. when
  // Lidarr writes to /music but Audioseerr mounts the library at /data).
  // Empty/null means no remapping.
  mediaPathMap           String?
  setupComplete          Boolean @default(false)
  // When true, a cron job pre-downloads each enabled user's Daily/Discover mix
  // "new" tracks into temporary (ephemeral) storage so they play full-length
  // instantly; unkept temp tracks are auto-pruned (src/lib/jobs).
  preDownloadMixes       Boolean @default(false)
}

// Snapshot of a Spotify playlist's track IDs at the time of the user's last
// import. Used to badge "X new tracks since last import" when re-previewing
// the same playlist. trackIdsJson is a stringified JSON array of Spotify
// track IDs (SQLite has no native array type).
model SpotifyPlaylistImport {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlistId     String
  trackIdsJson   String
  lastImportedAt DateTime @default(now())

  @@unique([userId, playlistId])
}

model ApiCache {
  key       String   @id
  value     String
  expiresAt DateTime

  @@index([expiresAt])
}

// Polymorphic per-user likes for tracks, albums, and artists. Cached metadata
// (title/artistName/coverUrl/albumMbid) lets us render a "Liked items" view
// later without re-fetching MusicBrainz for every row.
//
// targetId conventions:
//   - ALBUM  → release-group MBID
//   - ARTIST → artist MBID
//   - TRACK  → recording MBID (stable across reissues; album context is
//              captured separately in albumMbid for navigation)
model Like {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType   LikeTargetType
  targetId     String
  title        String
  artistName   String?
  albumMbid    String?
  albumTitle   String?
  coverUrl     String?
  createdAt    DateTime       @default(now())

  @@unique([userId, targetType, targetId])
  @@index([userId, targetType])
}

// Per-user album-search history. Upserted on every search submission so a
// repeated query bumps `lastSearchedAt` rather than creating a duplicate row.
model RecentSearch {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query          String
  lastSearchedAt DateTime @default(now())

  @@unique([userId, query])
  @@index([userId, lastSearchedAt])
}

model Invite {
  token       String    @id
  createdById String
  createdBy   User      @relation("InvitesCreated", fields: [createdById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  usedAt      DateTime?
  usedById    String?
  usedBy      User?     @relation("InvitesUsed", fields: [usedById], references: [id], onDelete: SetNull)

  @@index([expiresAt])
}

// User-curated ordered list of tracks the user has in their Lidarr library.
// Tracks live in PlaylistTrack with dense 1-indexed positions; reorders
// renumber the affected rows in a single transaction.
model Playlist {
  id          String          @id @default(cuid())
  // Nullable: system (editorial) playlists have no owner. User playlists always
  // set it; the cascade only fires for those.
  userId      String?
  user        User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  coverUrl    String?
  // Owner-controlled visibility flag. When true, any signed-in user can view
  // (read-only) the playlist via /playlists/[id] and it appears in their
  // "Shared with you" section. Tracks the viewer doesn't have library
  // coverage for stay listed but won't stream (Phase 2 stream gate).
  isShared    Boolean         @default(false)
  // System (editorial) playlist: Spotify-style mood/genre playlist owned by no
  // one, visible to everyone, and refreshed weekly from Last.fm tags. slug is
  // the stable identity the SYSTEM_PLAYLISTS code definitions upsert against;
  // tagsJson is the JSON array of Last.fm tags the refresh pulls from;
  // nextRefreshAt drives the staggered weekly refresh (src/lib/jobs).
  isSystem        Boolean     @default(false)
  slug            String?     @unique
  tagsJson        String?
  nextRefreshAt   DateTime?
  lastRefreshedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  tracks      PlaylistTrack[]
  systemTracks SystemPlaylistTrack[]
  subscriptions PlaylistSubscription[]

  @@index([userId])
  @@index([isShared])
  @@index([isSystem, nextRefreshAt])
}

// Tracks of a system (editorial) playlist. Unlike PlaylistTrack (a resolved
// library row), these are discovery-shaped: title/artist/album/cover + a Deezer
// 30s preview, with NO MusicBrainz resolution — so the weekly refresh is cheap
// and playlists fill fast. They render like mix "new" picks (preview + per-track
// download); the download resolves to MusicBrainz lazily on click/subscribe.
model SystemPlaylistTrack {
  id          String   @id @default(cuid())
  playlistId  String
  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  position    Int
  title       String
  artistName  String
  albumTitle  String?
  coverUrl    String?
  previewUrl  String?
  durationMs  Int?

  @@index([playlistId, position])
}

// Per-user subscription to a system (editorial) playlist. On the playlist's
// weekly refresh, each subscriber gets the new tracks auto-downloaded into temp
// (ephemeral) storage — the same path discovery-mix pre-download uses.
model PlaylistSubscription {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, playlistId])
  @@index([playlistId])
}

// One play counted per track per "playthrough." A play is recorded once
// playback crosses the Last.fm-style threshold (50% of the track or 4 minutes,
// whichever is sooner; tracks shorter than 30s never count). The threshold
// match means we can later compare against Last.fm scrobbles apples-to-apples.
//
// recordingMbid follows the same convention as PlaylistTrack — a real
// MusicBrainz recording MBID where we have one, otherwise a `lidarr:<id>`
// pseudo-id (Lidarr doesn't expose recording MBIDs). albumMbid + artistName
// are denormalized so we can render "most-played albums/artists" without
// joining against external metadata.
model PlayHistory {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recordingMbid String
  albumMbid     String?
  artistName    String
  title         String
  durationMs    Int?
  playedMs      Int
  playedAt      DateTime @default(now())

  @@index([userId, playedAt])
  @@index([userId, recordingMbid])
  @@index([userId, albumMbid])
}

// One row per track in a playlist. Duplicates of the same recordingMbid are
// allowed (sometimes you want the same track twice in a row).
//
// trackFileId is the last-known Lidarr id and may go stale across re-imports.
// Lidarr's track API doesn't expose recording MBIDs, so the heal path keys on
// `albumPosition` (1-indexed track number on the album) — the same key the
// album page uses via buildTrackFileLookup. recordingMbid is kept for future
// MB-side lookups and as a stable display identity.
model PlaylistTrack {
  id            String   @id @default(cuid())
  playlistId    String
  playlist      Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  position      Int
  recordingMbid String
  // Nullable since the slskd switchover: a playlist can now hold a track we
  // don't have yet (auto-fetching) or one served from our own DownloadedTrack
  // library (no Lidarr id). When set, it's the last-known Lidarr trackFileId.
  // Streamability is resolved at render time from trackFileId OR a
  // DownloadedTrack match (recordingMbid, falling back to albumMbid+position).
  trackFileId   Int?
  albumMbid     String
  albumPosition Int
  title         String
  artistName    String
  albumTitle    String?
  coverUrl      String?
  durationMs    Int?
  addedAt       DateTime @default(now())

  @@index([playlistId, position])
}

// Audioseerr-owned single-track library — the slskd equivalent of LibraryItem.
// One row per single song we've pulled down via Soulseek and can stream
// directly off disk, independent of Lidarr. Created when a TRACK request
// finishes downloading (the request's status remains the lifecycle source of
// truth; this table is "available-only", i.e. its presence means playable).
//
// Identity is (albumMbid, albumPosition): every track request originates from
// an album page so both are always known, and the album page joins on absolute
// position (the same key buildTrackFileLookup uses for Lidarr). recordingMbid
// is indexed as the stable cross-release identity that playlists join on.
model DownloadedTrack {
  id            String   @id @default(cuid())
  recordingMbid String?
  albumMbid     String
  albumPosition Int
  title         String
  artistName    String
  albumTitle    String?
  coverUrl      String?
  durationMs    Int?
  // File location as reported by slskd (pre path-map). Resolved to a path
  // Audioseerr can read at stream time via the shared mediaPathMap.
  filePath      String
  format        String?
  bitrate       Int?
  sizeBytes     Int?
  createdAt     DateTime @default(now())
  // Discovery-mix pre-download temp tracks. ephemeral=true means this was
  // auto-fetched for a Daily/Discover mix and is hidden from the library until
  // the user keeps it (likes it or adds it to a playlist → graduated to
  // ephemeral=false). expiresAt is when an unkept temp track becomes eligible
  // for the prune job (src/lib/jobs/pruneEphemeralTracks). Real library tracks
  // keep the defaults and are structurally out of the prune's scope.
  ephemeral     Boolean  @default(false)
  expiresAt     DateTime?
  users         UserDownloadedTrack[]

  @@unique([albumMbid, albumPosition])
  @@index([recordingMbid])
  @@index([ephemeral, expiresAt])
}

// Per-user visibility onto DownloadedTrack, mirroring UserLibraryItem. The file
// is stored once; this partitions who can see and stream it. A user gets a row
// when they request the track or add it to a playlist. Admins bypass the
// filter (same convention as the album library).
model UserDownloadedTrack {
  id                String          @id @default(cuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  downloadedTrackId String
  downloadedTrack   DownloadedTrack @relation(fields: [downloadedTrackId], references: [id], onDelete: Cascade)
  addedAt           DateTime        @default(now())

  @@unique([userId, downloadedTrackId])
  @@index([userId])
}
